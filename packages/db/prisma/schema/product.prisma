enum MarketingTaskType {
  SHORT @map("short")
  LONG  @map("long")
}

enum MarketingTaskContentType {
  REPLY @map("reply")
  POST  @map("post")
  VIDEO @map("video")
  IMAGE @map("image")
}

enum MarketingTaskNetwork {
  X        @map("x")
  REDDIT   @map("reddit")
  LINKEDIN @map("linkedin")
  YOUTUBE  @map("youtube")
  META     @map("meta")
}

model Product {
  id                 String                 @id @default(uuid()) @db.Uuid
  generalDescription String                 @map("general_description")
  plusSides             String                 @map("plus_sides")
  minusSides            String                 @map("minus_sides")
  mainCompetitors       String                 @map("main_competitors")
  competitorWeaknesses  String                 @default("") @map("competitor_weaknesses")
  websiteUrl         String                 @default("") @map("website_url")
  onboardingConfig            Json                   @default("{}") @map("onboarding_config")
  marketingTasksGeneratedAt     DateTime?              @map("marketing_tasks_generated_at") @db.Timestamptz
  createdAt                   DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz
  marketingTasks     ProductMarketingTask[]
  sentiments         ProductSentiment[]
  growthFeedEntries  ProductGrowthFeedEntry[]

  @@map("products")
}

model ProductMarketingTask {
  id             String                   @id @default(uuid()) @db.Uuid
  productId      String                   @map("product_id") @db.Uuid
  title          String
  description    String
  taskType       MarketingTaskType        @map("task_type")
  contentType    MarketingTaskContentType @map("content_type")
  network        MarketingTaskNetwork
  subtasks       Json                     @default("[]")
  priority       Int
  targetDate     DateTime                 @map("target_date") @db.Timestamptz
  scheduledStart DateTime                 @map("scheduled_start") @db.Timestamptz
  scheduledEnd   DateTime                 @map("scheduled_end") @db.Timestamptz
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  trendId        String?                  @map("trend_id") @db.Uuid
  product        Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  trend          Trend?                   @relation(fields: [trendId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([targetDate])
  @@index([priority])
  @@index([productId, scheduledStart, scheduledEnd])
  @@map("product_marketing_tasks")
}
